# ── LLM 配置（OpenAI 兼容接口，如 DeepSeek）──
# 优先级：系统环境变量 DEEPSEEK_API_KEY > 本文件 OPENAI_API_KEY
# DEEPSEEK_API_KEY 已配在系统环境变量中时，本文件无需填写
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL_NAME=deepseek-v4-flash

# ── 搜索配置 ──
# Tavily Search API (https://tavily.com/) - 推荐，结果结构化
TAVILY_API_KEY=tvly-your-tavily-api-key-here
# DuckDuckGo 免费搜索（无需 API Key，默认启用）
USE_DUCKDUCKGO=true

# ── 网络代理（中国大陆用户必需）────────────
# 如果直接连接无法访问 DuckDuckGo 或 DeepSeek，配置本地代理工具地址
# 系统会自动尝试：有代理时先走代理 → 失败后降级为直连
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
